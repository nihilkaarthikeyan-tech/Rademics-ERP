# ─────────────────────────────────────────────────────────────────────────────
# Rademics ERP — STAGING env template (runbook §4). Copy to .env.staging ON THE
# VPS (chmod 600) and fill real values. NEVER commit the filled file.
#
# Staging is isolated from prod: its own DB/MinIO creds and its own JWT/encryption
# secrets, so a staging leak can't touch prod, and a token minted on staging is
# worthless against prod. Generate fresh secrets — do NOT copy prod's.
#   JWT/secret:  openssl rand -hex 32
#   enc key:     openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# --- Seed: staging Super Admin (change after first login) ---
SEED_SUPERADMIN_EMAIL=admin@staging.rademics.local
SEED_SUPERADMIN_PASSWORD=ChangeMeStaging123!

# --- Postgres (own creds; NOT prod's) ---
POSTGRES_USER=rademics
POSTGRES_PASSWORD=__staging_db_pw__
POSTGRES_DB=rademics
DATABASE_URL=postgresql://rademics:__staging_db_pw__@postgres:5432/rademics?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (own creds; NOT prod's) ---
MINIO_ROOT_USER=rademics
MINIO_ROOT_PASSWORD=__staging_minio_pw__
S3_ENDPOINT=https://staging-storage.52digit.com
S3_BUCKET=rademics-files
S3_ACCESS_KEY=rademics
S3_SECRET_KEY=__staging_minio_pw__
S3_REGION=us-east-1

# --- ClamAV (only if started with --profile scan) ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- SMTP ---
# Point staging at a catch-all/dev inbox (e.g. Mailtrap) so test runs never email
# real people. Leaving it unset just queues+fails sends harmlessly.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Rademics ERP (staging) <no-reply@staging.rademics.local>"

# --- Auth / JWT (fresh, staging-only) ---
JWT_ACCESS_SECRET=__staging_access_secret__
JWT_REFRESH_SECRET=__staging_refresh_secret__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Field-level encryption (fresh, staging-only) ---
FIELD_ENCRYPTION_KEY=__staging_base64_32byte_key__

# --- App URLs / CORS (staging subdomains) ---
API_PORT=4000
INTERNAL_APP_URL=https://staging.52digit.com
PORTAL_APP_URL=https://staging-clientportal.52digit.com
NEXT_PUBLIC_API_URL=https://staging-api.52digit.com/api
COMPANY_TIMEZONE=Asia/Kolkata

# --- Observability ---
# Reuse the same Sentry projects but set SENTRY_ENVIRONMENT=staging (below) so
# staging events are filterable and don't pollute prod alert rules.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PORTAL_SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=

# --- Turnstile (use Cloudflare's testing keys on staging) ---
# 1x00000000000000000000AA / 1x0000000000000000000000000000000AA always-pass keys
# let you exercise the widget without a real challenge.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- AI providers (optional; features degrade to rule-based if unset) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
