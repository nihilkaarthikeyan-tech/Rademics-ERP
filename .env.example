# ─────────────────────────────────────────────────────────────
# Rademics ERP — root env template. Copy to `.env` and adjust.
# Secrets belong ONLY here (server-side), never in the frontend
# bundle or the repo (Spec §10).
# ─────────────────────────────────────────────────────────────

# --- Seed: real Super Admin owner (Spec §5.1, §11) ---
# The first system owner. Password must be ≥10 chars incl. a number. Change after first login.
SEED_SUPERADMIN_EMAIL=admin@rademics.local
SEED_SUPERADMIN_PASSWORD=ChangeMe123!

# --- Postgres (Spec §12) ---
POSTGRES_USER=rademics
POSTGRES_PASSWORD=rademics_dev_pw
POSTGRES_DB=rademics
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rademics:rademics_dev_pw@localhost:5432/rademics?schema=public

# --- Redis (cache/sessions + BullMQ) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=rademics
MINIO_ROOT_PASSWORD=rademics_dev_pw
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=rademics-files
S3_ACCESS_KEY=rademics
S3_SECRET_KEY=rademics_dev_pw
S3_REGION=us-east-1

# --- ClamAV (virus scanning, Spec §5.6 / §12) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Mailhog (dev SMTP; prod uses a generic SMTP provider, Spec §12) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Rademics ERP <no-reply@rademics.local>"
MAILHOG_UI_PORT=8025

# --- Auth / JWT (Spec §5.1, §10) ---
# Generate strong random values for real environments.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Field-level encryption key for salary/PII (Spec §10) ---
# 32-byte key, base64. Replace in real environments.
FIELD_ENCRYPTION_KEY=ZGV2X29ubHlfMzJieXRlX2tleV9jaGFuZ2VfbWVfcGxz

# --- App URLs / CORS ---
API_PORT=4000
INTERNAL_APP_URL=http://localhost:3000
PORTAL_APP_URL=http://localhost:3001
COMPANY_TIMEZONE=Asia/Kolkata

# --- Observability (Spec §11) ---
# API + internal-app server-side error reporting (shared: SENTRY_DSN also feeds
# apps/internal's server instrumentation). Empty = Sentry disabled (no-op), safe for local.
SENTRY_DSN=
# Browser (client-side) error reporting for apps/internal. Public by necessity.
NEXT_PUBLIC_SENTRY_DSN=
# Portal's own error reporting — separate project, separate vars (internal + portal
# share one Docker build, so a single var pair would collapse both apps' reports
# together). Server-side portal DSN is just SENTRY_DSN set on the portal container.
NEXT_PUBLIC_PORTAL_SENTRY_DSN=
# Prometheus scrapes GET /api/metrics — no key needed; firewall it to the monitoring net in prod.

# --- Turnstile CAPTCHA (Spec §10 bot protection) ---
# Empty = no-op on both server (TurnstileService) and browser (Turnstile component).
TURNSTILE_SECRET_KEY=
# Public by necessity — rendered into the login page HTML. Baked in at BUILD time
# (Next.js NEXT_PUBLIC_* convention), so changing it needs an image rebuild.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- AI providers (Spec §7; features degrade gracefully to rule-based if unset, §25) ---
# Names MUST match config/env.ts (the gateway reads these exact keys). Server-side only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
