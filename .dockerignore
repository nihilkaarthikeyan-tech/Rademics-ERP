# Build context hygiene — keep the image lean and reproducible.
# node_modules are reinstalled inside the image from the lockfile.
**/node_modules
.git
.github
.turbo
**/.next
**/dist
**/*.tsbuildinfo
.docker-data
# Never bake local secrets into the image; env is supplied at runtime via env_file.
.env
.env.*
!.env.example
*.log
*.docx
