{
  "name": "@rademics/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Rademics ERP Desktop Agent — Windows companion app for check-in/out and activity tracking",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "bundle": "electron-vite build",
    "dist:win": "pnpm run bundle && electron-builder --win"
  },
  "dependencies": {
    "@rademics/permissions": "workspace:*",
    "@rademics/types": "workspace:*",
    "@rademics/ui": "workspace:*",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
