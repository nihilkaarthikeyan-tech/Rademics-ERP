// Rademics ERP — Prisma schema.
// Phase 1 (Foundation) scope: auth, RBAC capability grants, sessions, audit log,
// settings. Later phases extend this (People/Org in Phase 2, etc.).
//
// Enum string values MUST match @rademics/permissions and @rademics/types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Seven roles (Spec §2/§3). Freelancer is NOT a role — it is EMPLOYEE + resourceType FREELANCE.
enum Role {
  SUPER_ADMIN
  HR
  PM
  TEAM_LEAD
  EMPLOYEE
  CLIENT
  FINANCE
}

enum ResourceType {
  INTERNAL
  FREELANCE
}

/// Grant value for a capability, per role (Spec §3).
enum Grant {
  ALLOW
  DENY
  SCOPED
}

/// Account lifecycle at the auth layer (distinct from employment status in Phase 2).
enum UserStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

enum AuthTokenType {
  INVITE
  PASSWORD_RESET
}

/// Employment status (Spec §5.2) — distinct from the auth-level UserStatus.
enum EmploymentStatus {
  ACTIVE
  ON_NOTICE
  EXITED
}

/// Business verticals a department maps to for P&L (Spec §5.2).
enum BusinessVertical {
  PUBLICATIONS
  DESIGN
  WEB
  SUPPORT
}

/// A person who can authenticate: staff, freelancer (EMPLOYEE+FREELANCE), or client user.
model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  name         String
  passwordHash String? // null until the invite set-password link is used
  role         Role
  resourceType ResourceType @default(INTERNAL)
  status       UserStatus   @default(INVITED)

  // Failed-login lockout (Spec §5.1): lock 15 min after 5 consecutive failures.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  // ── People & Org profile (Spec §5.2) ──
  phone            String?
  photoUrl         String?
  employeeCode     String?           @unique
  joinDate         DateTime?
  employmentStatus EmploymentStatus?

  departmentId String?     @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  teamId       String?     @db.Uuid
  team         Team?       @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)

  reportingManagerId String? @db.Uuid
  reportingManager   User?   @relation("Reports", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  reports            User[]  @relation("Reports")

  ledTeams Team[] @relation("TeamLead")

  // ── Salary / PII, field-level encrypted at rest (Spec §10). Ciphertext only. ──
  salaryCiphertext      String?
  bankAccountCiphertext String?
  govIdCiphertext       String?

  // ── Freelancer (Spec §5.2) — resourceType = FREELANCE ──
  payPerDeliverable Decimal? @db.Decimal(12, 2)
  activeEngagement  Boolean  @default(true)

  skills UserSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  authTokens    AuthToken[]
  auditLogs     AuditLog[]     @relation("AuditActor")

  @@index([role])
  @@index([status])
  @@index([departmentId])
  @@index([teamId])
  @@map("users")
}

/// Refresh-token rotation family for server-side revocation (Spec §5.1, §10).
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique // only the hash is stored
  familyId     String    @db.Uuid
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  createdByIp  String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

/// Single-use tokens for invite + password reset (Spec §5.1). Reset link valid 30 min.
model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId])
  @@map("auth_tokens")
}

/// Capability grants per role (Spec §3). Seeded from @rademics/permissions matrix,
/// then editable by Super Admin without a code change.
model RoleCapability {
  id            String @id @default(uuid()) @db.Uuid
  role          Role
  capabilityKey String
  grant         Grant

  updatedAt DateTime @updatedAt

  @@unique([role, capabilityKey])
  @@index([role])
  @@map("role_capabilities")
}

/// Append-only audit trail (Spec §5.10, §10). No update/delete path exists anywhere.
model AuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  actorId    String? @db.Uuid
  actor      User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String? // denormalized so entries survive user changes
  action     String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

/// Admin Settings store (Spec §4, §23). Business-rule defaults live here, not in code.
model Setting {
  key         String   @id
  value       Json
  updatedById String?  @db.Uuid
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

/// Department → maps to a business vertical for P&L (Spec §5.2).
model Department {
  id       String           @id @default(uuid()) @db.Uuid
  name     String           @unique
  vertical BusinessVertical

  teams   Team[]
  members User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

/// A team has exactly one Team Lead (Spec §5.2).
model Team {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  departmentId String  @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  teamLeadId   String? @db.Uuid
  teamLead     User?   @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)

  members User[] @relation("TeamMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("teams")
}

/// Admin-managed skill tag list (Spec §5.9).
model SkillTag {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique
  users     UserSkill[]
  createdAt DateTime    @default(now())

  @@map("skill_tags")
}

/// Many-to-many: users ↔ skill tags.
model UserSkill {
  userId  String   @db.Uuid
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String   @db.Uuid
  skill   SkillTag @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
  @@map("user_skills")
}
