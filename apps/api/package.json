{
  "name": "@rademics/api",
  "version": "0.1.0",
  "private": true,
  "description": "Rademics ERP backend (NestJS)",
  "scripts": {
    "build": "nest build",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- prisma db seed",
    "seed:demo": "dotenv -e ../../.env -- ts-node scripts/demo-users.ts",
    "demo:seed": "dotenv -e ../../.env -- ts-node prisma/demo-seed.ts",
    "verify:phase1": "dotenv -e ../../.env -- ts-node scripts/verify-phase1.ts",
    "verify:phase2": "dotenv -e ../../.env -- ts-node scripts/verify-phase2.ts",
    "verify:phase3": "dotenv -e ../../.env -- ts-node scripts/verify-phase3.ts",
    "verify:phase4": "dotenv -e ../../.env -- ts-node scripts/verify-phase4.ts",
    "verify:phase5": "dotenv -e ../../.env -- ts-node scripts/verify-phase5.ts",
    "verify:phase6": "dotenv -e ../../.env -- ts-node scripts/verify-phase6.ts",
    "verify:phase7": "dotenv -e ../../.env -- ts-node scripts/verify-phase7.ts",
    "verify:phase8": "dotenv -e ../../.env -- ts-node scripts/verify-phase8.ts",
    "verify:phase9": "dotenv -e ../../.env -- ts-node scripts/verify-phase9.ts",
    "verify:phase10": "dotenv -e ../../.env -- ts-node scripts/verify-phase10.ts",
    "loadtest": "dotenv -e ../../.env -- ts-node scripts/loadtest.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@rademics/permissions": "workspace:*",
    "@rademics/types": "workspace:*",
    "@sentry/node": "^10.65.0",
    "bullmq": "^5.34.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "minio": "^8.0.7",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.19.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.6",
    "autocannon": "^8.0.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
